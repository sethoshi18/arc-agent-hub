# Arc Agent Hub Environment Variables

# --- Circle Modular Wallets (Passkey Authentication) ---
# Get these from https://console.circle.com
# 1. Create a project
# 2. Go to API Keys > Client-Side
# 3. Add your domain to Allowed Domains (localhost for dev)
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=your-circle-client-key
NEXT_PUBLIC_CIRCLE_CLIENT_URL=https://modular-sdk.circle.com/v1/rpc/w3s/buidl

# --- Nanopayments (Circle Gateway) ---
# Seller wallet — receives nanopayments from agents
SELLER_ADDRESS=0xYourSellerAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# Buyer wallet — the AI agent that pays for services
BUYER_ADDRESS=0xYourBuyerAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# Agent buyer config (optional)
BASE_URL=http://localhost:3000
DEPOSIT_AMOUNT=1
